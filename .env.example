# Karnaf CRM Core - environment template.
# Copy to .env (root) for local dev. Edge Function secrets live in Supabase
# project secrets and never in this repo.

# --- Frontend (Vite, prefixed VITE_*) -----------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_FUNCTIONS_BASE_URL=https://<project-ref>.functions.supabase.co
# Optional Sentry-compatible POST endpoint for unhandled errors. Leaving
# blank disables the global reporters; the helper falls back to no-op.
VITE_SENTRY_DSN=
VITE_RELEASE=
VITE_ENV=production

# --- Backend / Edge Function secrets ------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CORS allowlist for browser-facing Edge Functions
CORS_ALLOWED_ORIGINS=http://localhost:5173

# WhatsApp / Meta
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_FALLBACK_TEMPLATE=karnaf_followup_v1

# WhatsApp / WATI (only if Meta not used)
WATI_TOKEN=
WATI_API_URL=https://live-mt-server.wati.io

# Webhook HMAC secrets
INTAKE_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_SECRET=
EMAIL_WEBHOOK_SECRET=

# Internal cron auth (sla-worker)
SLA_WORKER_SECRET=

# AI runtime
# Supported values for health/config checks: openai, gemini/google.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
